rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Store hero/logo images and menu item photos, uploaded by their owner
    // before (or after) the store's Firestore doc exists — keyed by the
    // owner's uid rather than storeId, so there's no chicken-and-egg
    // problem requiring a Firestore lookup during initial registration.
    // Anyone signed in (visitors are auto-signed-in anonymously, see
    // lib/firebase.ts) can view them; only that specific owner can upload,
    // and only with a session that's passed OTP 2FA recently — same
    // freshness check as firestore.rules' isVerifiedOwner().
    match /ownerUploads/{uid}/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.auth.token.otpVerifiedAt is number
        && request.auth.token.otpVerifiedAt >= request.auth.token.auth_time * 1000
        && request.time.toMillis() - request.auth.token.otpVerifiedAt < 24 * 60 * 60 * 1000
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
