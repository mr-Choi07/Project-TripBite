# Korea Tourism Organization TourAPI4.0 service key
# Issue one at https://www.data.go.kr (search "TourAPI") and paste the decoding key below.
# When left unset, src/lib/tourApi.ts automatically falls back to mock data
# shaped like a real locationBasedList2 response, so the app still runs.
VITE_TOUR_API_KEY=

# Firebase project config (console.firebase.google.com -> Project settings -> General -> Your apps)
# Used for: anonymous auth (tourist visits, invisible) + email/password auth (store owner, gates /stats)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Naver Cloud Platform Maps (Dynamic Map) client ID
# console.ncloud.com -> AI·Application Service -> Maps -> Application registration
# Must whitelist the exact web service URL(s) you'll load this from (localhost + deploy domain).
# When left unset, the course-screen map shows a graceful "지도를 불러오지 못했습니다" fallback.
VITE_NAVER_MAP_CLIENT_ID=
